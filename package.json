{
  "name": "pastekey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "verify": "bun run typecheck && bun run test && bun run build && wrangler deploy --dry-run",
    "deploy": "bun run verify && wrangler d1 migrations apply pastekey --remote && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply pastekey --local",
    "db:migrate:remote": "wrangler d1 migrations apply pastekey --remote",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@cloudflare/kumo": "2.7.0",
    "@phosphor-icons/react": "2.1.10",
    "@simplewebauthn/server": "13.3.2",
    "hono": "4.12.29",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@cloudflare/workers-types": "5.20260711.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
